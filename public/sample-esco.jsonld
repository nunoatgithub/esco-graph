{
  "@context": {
    "preferredLabel": "http://example.org/preferredLabel",
    "broaderSkill": { "@id": "http://example.org/broaderSkill", "@type": "@id" },
    "relatedSkill": { "@id": "http://example.org/relatedSkill", "@type": "@id" },
    "hasEssentialSkill": { "@id": "http://example.org/hasEssentialSkill", "@type": "@id" },
    "hasOptionalSkill": { "@id": "http://example.org/hasOptionalSkill", "@type": "@id" }
  },
  "@graph": [
    {
      "@id": "occupation:data-analyst",
      "@type": "occupation",
      "preferredLabel": { "en": "Data analyst" },
      "hasEssentialSkill": ["skill:statistics", "skill:data-cleaning"],
      "hasOptionalSkill": ["skill:data-visualization"]
    },
    {
      "@id": "skill:statistics",
      "@type": "skill",
      "preferredLabel": { "en": "Statistics" },
      "broaderSkill": ["skill:mathematics"],
      "relatedSkill": ["skill:data-cleaning"]
    },
    {
      "@id": "skill:data-cleaning",
      "@type": "skill",
      "preferredLabel": { "en": "Data cleaning" },
      "relatedSkill": ["skill:data-visualization"]
    },
    {
      "@id": "skill:data-visualization",
      "@type": "skill",
      "preferredLabel": { "en": "Data visualization" },
      "relatedSkill": ["skill:statistics"]
    },
    {
      "@id": "skill:mathematics",
      "@type": "skill",
      "preferredLabel": { "en": "Mathematics" }
    }
  ]
}
